# ===========================================
# Eventix Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git.

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=eventix_db
DB_PORT=3306

# App URL (no trailing slash)
APP_URL=http://localhost/eventix
